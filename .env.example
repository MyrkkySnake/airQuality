# ============================================================
# Air Quality Monitoring System — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── Telegram ──────────────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=7123456789:AAF_your_bot_token_here

# ── OpenAI ────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────
# SQLite (development — zero config):
DATABASE_URL=sqlite+aiosqlite:///./airquality.db

# PostgreSQL (production example):
# DATABASE_URL=postgresql+asyncpg://airuser:secret@localhost:5432/airquality

DB_ECHO=false

# ── API Server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=replace-with-a-long-random-string

# ── Map ───────────────────────────────────────────────────
MAP_CENTER_LAT=42.4597
MAP_CENTER_LON=59.6093
MAP_ZOOM=12

# ── Trend analysis ────────────────────────────────────────
# Number of hours to compare for trend detection
TREND_HOURS=6
